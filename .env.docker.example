# ============================
# Afilmory Docker 环境变量
# ============================

# --- 应用 ---
NODE_ENV=production
HOSTNAME=0.0.0.0
PORT=1841

# --- 应用端口 (宿主机映射) ---
APP_PORT=1841

# --- 数据库 (使用 1Panel 已有的 PostgreSQL) ---
# 格式: postgresql://用户名:密码@容器名:端口/数据库名
# 容器名: 在 VPS 上运行 docker ps | grep postgres 查看
# 示例: postgresql://postgres:你的密码@1panel-postgresql:5432/afilmory
DATABASE_URL=postgresql://afilmory:你的密码@1panel-postgresql:5432/afilmory

# --- Redis (使用 1Panel 已有的 Redis) ---
# 无密码: redis://容器名:6379/0
# 有密码: redis://:密码@容器名:6379/0
# 容器名: 在 VPS 上运行 docker ps | grep redis 查看
REDIS_URL=redis://1panel-redis:6379/0

# --- 加密密钥 (必需！请更换为随机值) ---
# 生成方法: 在 VPS 上运行 openssl rand -hex 32
CONFIG_ENCRYPTION_KEY=change_me_to_a_random_64_char_hex_string

# --- 超级管理员 ---
DEFAULT_SUPERADMIN_EMAIL=root@local.host
DEFAULT_SUPERADMIN_USERNAME=root

# --- OAuth 社交登录 (可选) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- 邮件服务 (可选) ---
# RESEND_API_KEY=
# RESEND_FROM=AFILMORY <notification@yourdomain.com>
